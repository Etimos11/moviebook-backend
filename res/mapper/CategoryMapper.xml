<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="platform.mapper.CategoryMapper">
    <resultMap id="CategoryMap" type="platform.entity.Category">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
    </resultMap>

    <insert id="insert" parameterType="platform.entity.Category">
        INSERT INTO category (name) VALUES (#{name})
    </insert>

    <select id="selectById" resultMap="CategoryMap">
        SELECT * FROM category WHERE id = #{id}
    </select>

    <select id="selectAll" resultMap="CategoryMap">
        SELECT * FROM category
    </select>

    <update id="update" parameterType="platform.entity.Category">
        UPDATE category SET name = #{name} WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM category WHERE id = #{id}
    </delete>
</mapper>