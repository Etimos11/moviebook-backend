<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="platform.mapper.MovieBookMapper">
    <resultMap id="MovieBookMap" type="platform.entity.MovieBook">
        <id column="id" property="id"/>
        <result column="type" property="type"/>
        <result column="category_id" property="categoryId"/>
        <result column="title" property="title"/>
        <result column="cover" property="cover"/>
        <result column="intro" property="intro"/>
        <result column="score" property="score"/>
        <result column="hot" property="hot"/>
        <result column="audit_status" property="auditStatus"/>
        <result column="apply_user_id" property="applyUserId"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <resultMap id="MovieBookDetailMap" type="platform.entity.MovieBook">
        <id column="id" property="id"/>
        <result column="type" property="type"/>
        <result column="title" property="title"/>
        <!-- 核心修复：在此处加回 cover 封面印记，确保通过 View 获取详情时封面存续 -->
        <result column="cover" property="cover"/>
        <result column="category_name" property="categoryName"/>
        <result column="intro" property="intro"/>
        <result column="score" property="score"/>
        <result column="hot" property="hot"/>
        <result column="note_count" property="noteCount"/>
    </resultMap>

    <insert id="insert" parameterType="platform.entity.MovieBook">
        INSERT INTO movie_book (type, category_id, title, cover, intro, score, hot, audit_status, apply_user_id, create_time)
        VALUES (#{type}, #{categoryId}, #{title}, #{cover}, #{intro}, #{score}, IFNULL(#{hot},0), #{auditStatus}, #{applyUserId}, NOW())
    </insert>

    <select id="selectById" resultMap="MovieBookMap">
        SELECT * FROM movie_book WHERE id = #{id}
    </select>

    <select id="selectByType" resultMap="MovieBookMap">
        SELECT * FROM movie_book WHERE type = #{type} AND audit_status = 1
    </select>

    <select id="selectByCategory" resultMap="MovieBookMap">
        SELECT * FROM movie_book WHERE category_id = #{categoryId} AND audit_status = 1
    </select>

    <select id="selectByAuditStatus" resultMap="MovieBookMap">
        SELECT * FROM movie_book WHERE audit_status = #{auditStatus}
    </select>

    <select id="searchByTitle" resultMap="MovieBookMap">
        SELECT * FROM movie_book WHERE title LIKE CONCAT('%', #{title}, '%') AND audit_status = 1
    </select>

    <select id="selectHot" resultMap="MovieBookMap">
        SELECT * FROM movie_book WHERE audit_status = 1 ORDER BY hot DESC LIMIT #{limit}
    </select>

    <select id="searchByTitleWithProc" resultMap="MovieBookMap">
        CALL proc_search_movie_book(#{keyword})
    </select>

    <select id="selectHotWithProc" resultMap="MovieBookMap">
        CALL proc_get_hot_movie_book(#{limit})
    </select>

    <update id="auditPassWithProc">
        CALL proc_audit_pass(#{id})
    </update>

    <update id="auditRejectWithProc">
        CALL proc_audit_reject(#{id})
    </update>

    <select id="selectAllApproved" resultMap="MovieBookMap">
        SELECT * FROM view_approved_movie_book
    </select>

    <select id="selectDetailById" resultMap="MovieBookDetailMap">
        SELECT * FROM view_movie_book_detail WHERE id = #{id}
    </select>

    <select id="selectAllDetail" resultMap="MovieBookDetailMap">
        SELECT * FROM view_movie_book_detail
    </select>

    <update id="update" parameterType="platform.entity.MovieBook">
        UPDATE movie_book
        SET type = #{type}, category_id = #{categoryId}, title = #{title},
        cover = #{cover}, intro = #{intro}, score = #{score}, hot = #{hot},
        audit_status = #{auditStatus}, apply_user_id = #{applyUserId}
        WHERE id = #{id}
    </update>

    <delete id="delete">
        DELETE FROM movie_book WHERE id = #{id}
    </delete>

    <update id="updateAuditStatus">
        UPDATE movie_book SET audit_status = #{status} WHERE id = #{id}
    </update>

    <update id="updateHot">
        UPDATE movie_book SET hot = #{hot} WHERE id = #{id}
    </update>

    <update id="updateScore">
        UPDATE movie_book SET score = #{score} WHERE id = #{id}
    </update>

    <!-- 调用统计存储过程 -->
    <select id="selectStatsOverview" resultType="map" statementType="CALLABLE">
        CALL proc_stat()
    </select>

    <!-- 实时重算引擎：将平均分与三大社交热度源（收藏/点赞/书评）完美融合更新 -->
    <!-- 完美的实时重算引擎：将平均分与四大社交热度源（收藏/点赞/随笔/留言）融合更新 -->
    <update id="recalculateScoreAndHot">
        UPDATE movie_book mb
        SET
        mb.score = COALESCE(
        (SELECT AVG(star) FROM note WHERE mb_id = #{id}),
        0.0
        ),
        mb.hot = (
        (SELECT COUNT(*) FROM collect WHERE mb_id = #{id})  +
        (SELECT COUNT(*) FROM likes WHERE note_id IN (SELECT id FROM note WHERE mb_id = #{id}))  +
        (SELECT COUNT(*) FROM note WHERE mb_id = #{id})  +
        (SELECT COUNT(*) FROM comment WHERE note_id IN (SELECT id FROM note WHERE mb_id = #{id}))
        )
        WHERE mb.id = #{id}
    </update>

</mapper>